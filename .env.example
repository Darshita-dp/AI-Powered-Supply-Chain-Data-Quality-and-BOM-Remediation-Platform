# BOM Guardian AI — environment template. Copy to .env and fill in.
# Everything runs locally with these defaults; Snowflake and hosted AI are optional.

# --- Application ---
BOMG_ENV=local                      # local | dev | prod
BOMG_LOG_LEVEL=INFO
BOMG_API_HOST=127.0.0.1
BOMG_API_PORT=8000
BOMG_CORS_ORIGINS=http://localhost:5173

# --- Authorization (DEMONSTRATION ONLY — not enterprise SSO/OIDC) ---
# API routes require `Authorization: Bearer <token>`. Built-in demo tokens:
#   demo-analyst-token (read), demo-steward-token (approve/reject), demo-admin-token.
# Override the token->identity map with a JSON object if desired, e.g.:
# BOMG_DEMO_USERS={"my-token": {"username": "alice", "role": "steward"}}
# The frontend uses VITE_DEMO_TOKEN (defaults to demo-steward-token) — see frontend/.env.

# --- Warehouse ---
BOMG_WAREHOUSE_BACKEND=duckdb       # duckdb | snowflake
BOMG_DUCKDB_PATH=warehouse/local/bom_guardian.duckdb

# --- Snowflake (only when BOMG_WAREHOUSE_BACKEND=snowflake) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=BOMG_ENGINEER
SNOWFLAKE_WAREHOUSE=BOMG_WH_XS
SNOWFLAKE_DATABASE=BOM_GUARDIAN
SNOWFLAKE_SCHEMA=RAW

# --- AI provider ---
BOMG_AI_PROVIDER=mock               # mock | snowflake_cortex | anthropic
BOMG_AI_CALL_BUDGET=200             # max AI calls per pipeline run
BOMG_AI_TIMEOUT_SECONDS=30
BOMG_SNOWFLAKE_AI_MODEL=claude-3-5-sonnet   # model for Snowflake Cortex AI_COMPLETE
ANTHROPIC_API_KEY=                  # optional; never required for tests
BOMG_ANTHROPIC_MODEL=claude-sonnet-5         # model for the optional Anthropic provider

# --- Data generation ---
BOMG_DATA_PROFILE=smoke             # smoke | demo | full
BOMG_RANDOM_SEED=20260716
